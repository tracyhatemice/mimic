# Mimic obfuscates UDP traffic (e.g. WireGuard) as TCP using eBPF.
#
# Each `config mimic` section runs one mimic instance against the named
# interface, using the per-interface config file (default
# /etc/mimic/<interface>.conf).
#
# To enable: set `enabled '1'`, ensure the interface exists, edit the
# referenced config_file with at least one `filter` line, then run
# `service mimic restart`.

config mimic 'eth0'
	option enabled '0'
	option interface 'eth0'
	option config_file '/etc/mimic/eth0.conf'
